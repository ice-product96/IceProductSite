# Copy this file to .env and fill in your values

# Secret key for sessions and CSRF (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret-key-32-chars-min

# Admin credentials
ADMIN_USERNAME=admin
# Generate hash with: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('your_password'))"
ADMIN_PASSWORD_HASH=$2b$12$placeholder_replace_with_real_bcrypt_hash

# Database (default: SQLite for dev)
DATABASE_URL=sqlite:///./ice_product.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/ice_product

# Max upload sizes (bytes)
MAX_ICON_SIZE=524288
MAX_SCREENSHOT_SIZE=2097152
